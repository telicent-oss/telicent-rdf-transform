# Minimal IES4 to IES Next mappings for the batch file mapper example
# Contains only the mappings needed for country and region data

@prefix ies: <http://ies.data.gov.uk/ontology/ies4#> .
@prefix ies_core: <http://purl.org/ies/core/v0/ont/> .
@prefix ies_top: <http://purl.org/ies/top/v0/ont/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .

# Class Mappings
ies:Country owl:equivalentClass ies_core:Country .
ies:RegionOfWorld owl:equivalentClass ies_core:RegionOfEarth .
ies:PlaceName owl:equivalentClass ies_core:Name .
ies:GeoIdentity owl:equivalentClass ies_core:Identifier .
ies:ISO3166_1Alpha_3 owl:equivalentClass ies_core:ISO3166_1Alpha_3 .

# Property Mappings
ies:hasName owl:equivalentProperty ies_core:hasName .
ies:inLocation owl:equivalentProperty ies_top:isPartOf .
ies:isIdentifiedBy owl:equivalentProperty ies_core:isIdentifiedBy .
ies:representationValue owl:equivalentProperty ies_core:representationValue .
ies:inScheme owl:equivalentProperty ies_core:inScheme .
