@prefix data: <http://example.org/rdf/data/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ies: <http://ies.data.gov.uk/ontology/ies4#> .
@prefix ies_top: <http://purl.org/ies/top/v0/ont/> .
@prefix ies_core: <http://purl.org/ies/core/v0/ont/> .

data:possible_world_001 a ies_top:Universe ;
    ies_top:isPartOf ies_top:pluriverse .

ies_top:pluriverse ies_core:hasName data:pluriverse_name .

data:pluriverse_name a ies_core:Name ;
    ies_core:representationValue "The Pluriverse" .