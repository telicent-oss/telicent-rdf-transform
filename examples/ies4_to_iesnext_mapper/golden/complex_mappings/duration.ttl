@prefix data: <http://example.org/rdf/data/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix ies: <http://ies.data.gov.uk/ontology/ies4#> .
@prefix ies_top: <http://purl.org/ies/top/v0/ont/> .
@prefix ies_core: <http://purl.org/ies/core/v0/ont/> .

data:meeting_001 a ies_core:Meeting ;
    ies_core:duration data:meeting_001_duration .

data:meeting_001_duration a ies_core:SetOfStatesWithParticularDuration ;
    ies_core:iso8601DurationRepresentation "PT2H30M"^^xsd:duration .


