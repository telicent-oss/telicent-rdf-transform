@prefix data: <http://example.org/rdf/data/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix ies: <http://ies.data.gov.uk/ontology/ies4#> .
@prefix ies_top: <http://purl.org/ies/top/v0/ont/> .
@prefix ies_core: <http://purl.org/ies/core/v0/ont/> .

data:car_1 a ies_core:Vehicle .

data:organisation_1 a ies_core:Organization .

data:car_1_create_event a ies_core:Create .

data:car_1_created a ies_core:Created ;
    ies_core:isTemporalPartOf data:car_1 ;
    ies_core:isPartOf data:car_1_create_event .

data:car_1_creator a ies_core:Creator ;
    ies_core:isPartOf data:car_1_create_event ;
    ies_core:isTemporalPartOf data:organisation_1 .
