@prefix data: <http://example.org/rdf/data/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix ies: <http://ies.data.gov.uk/ontology/ies4#> .
@prefix ies_top: <http://purl.org/ies/top/v0/ont/> .
@prefix ies_core: <http://purl.org/ies/core/v0/ont/> .
@prefix iso8601: <http://iso.org/iso8601#> .
@prefix ical: <http://www.w3.org/2002/12/cal/ical#> .


# an event that occurs daily at 8am with start no end
data:meeting_001 a ies_core:Meeting ;
    ies_top:isPartOf data:daily_at_8 .

iso8601:20260401T0800 a ies_core:ParticularPeriod ;
    ies_top:isAStartOf data:daily_at_8 ;
    ies_core:iso8601PeriodRepresentation "2026-04-01T08:00"^^xsd:string .

data:daily_at_8 a ies_core:RecurringTimespan ;
    ies_core:hasICalRepresentation  data:daily_at_8_representation .

data:daily_at_8_representation a ies_core:ICalRepresentation ;
    ical:rrule "FREQ=DAILY;BYHOUR=8;BYMINUTE=0"^^xsd:string ;
    ical:dtstart "2026-04-01T08:00"^^xsd:string .

# an event that occurs once a year with no start or end
data:christmas_day a ies_core:Activity ;
    ies_top:isPartOf data:once_a_year .

data:once_a_year a ies_core:RecurringTimespan ;
    ies_core:hasICalRepresentation  data:once_a_year_representation .
data:once_a_year_representation a ies_core:ICalRepresentation ;
     ical:rrule "FREQ=YEARLY;BYMONTH=12;BYMONTHDAY=25"^^xsd:string .

# an event that occurs once a month with unknown start and known end
data:payday_001 a ies_core:Activity ;
    ies_top:isPartOf data:once_a_month_001 .

iso8601:20270101 a ies_core:ParticularPeriod ;
    ies_top:isAFinishOf data:once_a_month_001 ;
    ies_core:iso8601PeriodRepresentation "2027-01-01"^^xsd:string .

data:once_a_month_001 a ies_core:RecurringTimespan ;
    ies_core:hasICalRepresentation  data:once_a_month_001_representation .

data:once_a_month_001_representation a ies_core:ICalRepresentation ;
     ical:rrule "FREQ=MONTHLY;BYMONTHDAY=28;UNTIL=20270101"^^xsd:string ;
     ical:dtend "2027-01-01"^^xsd:string .

# an event that occurs once a month with start and end
data:monthly_meeting_001 a ies_core:Meeting ;
    ies_top:isPartOf data:once_a_month_002 .

iso8601:20260101 a ies_core:ParticularPeriod ;
    ies_top:isAStartOf data:once_a_month_002 ;
    ies_core:iso8601PeriodRepresentation "2026-01-01"^^xsd:string .

iso8601:20271201 a ies_core:ParticularPeriod ;
    ies_top:isAFinishOf data:once_a_month_002 ;
    ies_core:iso8601PeriodRepresentation "2027-12-01"^^xsd:string .

data:once_a_month_002 a ies_core:RecurringTimespan ;
    ies_core:hasICalRepresentation  data:once_a_month_002_representation .

data:once_a_month_002_representation a ies_core:ICalRepresentation ;
    ical:rrule "FREQ=MONTHLY;BYMONTHDAY=1;UNTIL=20271201"^^xsd:string ;
    ical:dtstart "2026-01-01"^^xsd:string ;
    ical:dtend "2027-12-01"^^xsd:string .
