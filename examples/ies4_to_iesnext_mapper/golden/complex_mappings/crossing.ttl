@prefix data: <http://example.org/rdf/data/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ies: <http://ies.data.gov.uk/ontology/ies4#> .
@prefix ies_top: <http://purl.org/ies/top/v0/ont/> .
@prefix ies_core: <http://purl.org/ies/core/v0/ont/> .

data:FRA_border a ies_core:Location , data:crossing_of_FRA_and_BEL_set_of_overlapping_extents .

data:BEL_border a ies_core:Location , data:crossing_of_FRA_and_BEL_set_of_overlapping_extents .

data:crossing_of_FRA_and_BEL a ies_top:SpatiotemporalExtent ;
    ies_top:intersectionOf data:crossing_of_FRA_and_BEL_set_of_overlapping_extents .

data:crossing_of_FRA_and_BEL_set_of_overlapping_extents a ies_top:SetOfOverlappingSpatiotemporalExtents .
